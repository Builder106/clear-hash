# Ignore everything in the target directory except for release binaries Vercel needs.
target/**
!target/release
!target/x86_64-unknown-linux-gnu/release/**
!target/aarch64-unknown-linux-gnu/release/**

# Local-only / not needed in the deployed function.
.git/
.github/
.idea/
.vscode/
.DS_Store
*.swp

# Docker / Fly artifacts — Vercel doesn't use them.
Dockerfile
.dockerignore
fly.toml

# Asciinema source casts — Vercel only needs the rendered GIFs (which live in assets/).
assets/*.cast

# Local scratch dirs the CLI may create.
clearhash-rebuild-*/
